# Never bake secrets or local state into the image.
config.yml
config.*.yml
data/
*.exe
# The deploy dir holds Compose config, secrets (.env), and runtime state
# (deploy/data/) — none of it belongs in the build context, and its root-owned
# data/ would otherwise break the context transfer.
deploy/
# Docs/build artifacts are irrelevant to the binary.
README.md
Dockerfile
.dockerignore
.git
.gitignore
